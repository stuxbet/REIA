# Copy to .env. EXPO_PUBLIC_* vars are inlined into the app bundle (not secret).
# Point the app at your VPS backend (see /server). Use your VPS host/IP, not
# localhost — a phone running Expo Go can't reach your dev machine's localhost.
EXPO_PUBLIC_API_URL=http://YOUR_VPS_HOST:8787
# Must match the server's API_SHARED_SECRET. EXPO_PUBLIC_* is bundled into the
# app, so this is "soft" auth: it stops opportunistic abuse, not a determined
# reverse-engineer. Rotate it if leaked.
EXPO_PUBLIC_API_TOKEN=match-your-servers-API_SHARED_SECRET
