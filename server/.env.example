# Copy to .env and fill in. Never commit .env.
PORT=8787
# Free tier: https://app.rentcast.io/app/api
RENTCAST_API_KEY=your_rentcast_key_here
# REQUIRED. Shared secret the app must send as `Authorization: Bearer <secret>`.
# /enrich refuses requests without it (protects your metered quota). Long + random.
API_SHARED_SECRET=change-me-to-a-long-random-string
# Optional: restrict CORS to a web origin (a native app doesn't send one).
ALLOWED_ORIGIN=*
